{
  "name": "@splash-markets/splash-markets-sdk",
  "version": "0.0.5",
  "description": "TypeScript SDK for interacting with Splash Markets on Solana",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "prepublishOnly": "npm run build",
    "publish": "npm run build && npm publish --access public"
  },
  "keywords": [
    "solana",
    "splash-markets",
    "sdk",
    "blockchain",
    "defi",
    "prediction-markets"
  ],
  "author": "",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/splash-markets/splash-markets-sdk.git"
  },
  "dependencies": {
    "@solana-program/token": "^0.12.0",
    "@solana/kit": "^6.5.0"
  },
  "devDependencies": {
    "@types/node": "^25.0.8",
    "tsx": "^4.21.0",
    "typescript": "^5.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "sideEffects": false
}
